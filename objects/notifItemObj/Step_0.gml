timernot--;

semiposy = inity + sumposy;

speed = 30;
direction = point_direction(x,y, playerObj.x, playerObj.y)

if estadonot == notif.spaw {
	Not_Item_Spaw()
} else if estadonot == notif.show {
	Not_Item_Show()
} else if estadonot == notif.move {
	Not_Item_Move()
} else if estadonot == notif.fade {
	Not_Item_Fade()
} else if estadonot == notif.unb {
	Not_Item_Unb()
}